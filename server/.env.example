PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.com

DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=grantfinder
DB_USER=postgres
DB_PASSWORD=your-db-password

# Set to any value to disable the Playwright CA scraper (required on hosts without browser binaries)
PLAYWRIGHT_SKIP=true

# CareerOneStop API (optional) — register free at careeronestop.org/Developers/WebAPI/registration.aspx
# When set, enables scholarships and workforce training results from the DOL CareerOneStop database.
# Attribution required on any page showing COS results (see ToS condition 6).
CAREERONESTOP_USER_ID=your-user-id
CAREERONESTOP_TOKEN=your-api-token
